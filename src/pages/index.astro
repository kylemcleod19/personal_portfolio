---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const workEntries = await getCollection('work');
const featuredWork = workEntries
  .filter((e) => e.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Kyle McLeod — Product Leader & AI Builder">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <div class="max-w-2xl">
      <p class="text-accent-600 font-medium mb-3 text-sm tracking-wide uppercase">Product Leader · AI Builder</p>
      <h1 class="text-5xl font-bold text-gray-900 leading-tight mb-6">
        Seven years building B2B products. Now testing what AI makes possible.
      </h1>
      <p class="text-xl text-gray-500 leading-relaxed mb-10">
        I led product at B2B marketplaces for seven years. My thesis: AI-fluent product leaders can run a repeatable, scalable product org with 3–5 people instead of 100. Existing codebases aren't a moat — they're a liability. I'm actively building to test that.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="/work"
          class="bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-700 transition-colors"
        >
          See what I'm building →
        </a>
        <a
          href="https://www.linkedin.com/in/kyle--mcleod/"
          target="_blank"
          rel="noopener"
          class="text-gray-600 font-medium hover:text-gray-900 transition-colors flex items-center gap-1"
        >
          Connect on LinkedIn →
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredWork.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-24">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl font-bold text-gray-900">Selected work</h2>
        <a href="/work" class="text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
          View all →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredWork.map((entry) => (
          <a
            href={`/work/${entry.slug}`}
            class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-gray-300 hover:shadow-lg transition-all duration-300"
          >
            {entry.data.cover && (
              <div class="aspect-video bg-gray-50 overflow-hidden">
                <img
                  src={entry.data.cover}
                  alt={entry.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {entry.data.tags.map((tag: string) => (
                  <span class="text-xs font-medium bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-semibold text-gray-900 mb-2 group-hover:text-accent-600 transition-colors">
                {entry.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">
                {entry.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- About strip -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-4">About me</h2>
          <p class="text-gray-500 leading-relaxed mb-4">
            I spent seven years as a mechanical and manufacturing engineer — designing and building offshore drilling equipment at Schlumberger. That's where I learned how to think about systems, constraints, and what it actually takes to ship something real.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            I moved into product management and spent the next seven years at B2B marketplaces: first at AWL, building consumer quote flows and lead nurturing for insurance, then at MacroFab, where customers could upload a PCB design and get real-time quoting and ordering for custom electronics.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            Now I'm testing a thesis: that AI-fluent product leaders can build and ship at a scale that used to require large teams. I'm building products to prove it.
          </p>
          <p class="text-gray-500 leading-relaxed">
            When I'm not building, I'm probably fly fishing.
          </p>
        </div>
        <div class="flex flex-col items-center justify-center gap-8">
          <img
            src="/images/logos/schlumberger.svg"
            alt="Schlumberger"
            class="h-20 w-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          />
          <img
            src="/images/logos/awl.svg"
            alt="AWL"
            class="h-16 w-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          />
          <img
            src="/images/logos/macrofab.png"
            alt="MacroFab"
            class="h-20 w-auto grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroTerminal from '../components/HeroTerminal.tsx';
import CompanyLogos from '../components/CompanyLogos.tsx';

const workEntries = await getCollection('work');
const featuredWork = workEntries
  .filter((e) => e.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Kyle McLeod — Product Leader & AI Builder">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <p class="text-accent-600 font-medium mb-3 text-sm tracking-wide uppercase">Product Leader · AI Builder</p>
    <h1 class="text-5xl font-bold text-gray-900 leading-tight mb-8">
      Seven years building B2B products. Now testing what AI makes possible.
    </h1>
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-xl text-gray-500 leading-relaxed mb-10">
          I led product at B2B marketplaces for seven years. My thesis: AI-fluent product leaders can run a repeatable, scalable product org with 3–5 people instead of 100. Existing codebases aren't a moat — they're a liability. I'm actively building to test that.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="/work"
            class="bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-700 transition-colors"
          >
            See what I'm building →
          </a>
          <a
            href="https://www.linkedin.com/in/kyle--mcleod/"
            target="_blank"
            rel="noopener"
            class="text-gray-600 font-medium hover:text-gray-900 transition-colors flex items-center gap-1"
          >
            Connect on LinkedIn →
          </a>
        </div>
      </div>
      <div class="hidden md:block">
        <HeroTerminal client:load />
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredWork.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-24">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl font-bold text-gray-900">Selected work</h2>
        <a href="/work" class="text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
          View all →
        </a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredWork.map((entry) => (
          <a
            href={`/work/${entry.slug}`}
            class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden hover:border-gray-300 hover:shadow-lg transition-all duration-300"
          >
            {entry.data.cover && (
              <div class="aspect-video bg-gray-50 overflow-hidden">
                <img
                  src={entry.data.cover}
                  alt={entry.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                {entry.data.tags.map((tag: string) => (
                  <span class="text-xs font-medium bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-semibold text-gray-900 mb-2 group-hover:text-accent-600 transition-colors">
                {entry.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed line-clamp-2">
                {entry.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- About strip -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-4">About me</h2>
        <div class="max-w-3xl">
          <p class="text-gray-500 leading-relaxed mb-4">
            I spent seven years as a mechanical engineer at Schlumberger — designing and delivering offshore drilling equipment through regulated, multimillion-dollar development programs. That's where I learned how to think about systems, constraints, and what it actually takes to ship something real.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            I moved into product and spent the next seven years at B2B marketplaces. At AWL, I owned acquisition and call-center platforms for a ~$200M ARR insurance marketplace — ran platform-wide A/B testing programs that generated $12M in annual profit lift, and used marketplace data to shift investment toward call-based conversion, driving a 30% revenue increase in Health and Medicare.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            At MacroFab, I went from Sr. PM to Director of Product, leading a 10-person cross-functional dev org and mentoring a team of product managers. I owned the pricing, quoting, and operational decisioning platforms for a ~$50M ARR electronics marketplace — deployed an ML-driven pricing engine that automated 98% of transactions, improved panel margins from 25% to 41%, and drove a 114% increase in conversion. I also led productization of an agentic AI workflow for interpreting customer manufacturing documents, defining the human-in-the-loop review process and accuracy guardrails for production deployment.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            Now I'm testing a thesis: that AI-fluent product leaders can build and ship at a scale that used to require large teams. I'm building products to prove it.
          </p>
          <p class="text-gray-500 leading-relaxed">
            When I'm not building, I'm probably fly fishing.
          </p>
        </div>
        <div class="mt-10 pt-8 border-t border-gray-200">
          <CompanyLogos client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

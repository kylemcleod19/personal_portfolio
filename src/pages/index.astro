---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroTerminal from '../components/HeroTerminal.tsx';
import CompanyLogos from '../components/CompanyLogos.tsx';

const workEntries = await getCollection('work');
const featuredWork = workEntries
  .filter((e) => e.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Kyle McLeod — Product Leader & AI Builder">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
    <p class="text-accent-600 font-medium mb-3 text-sm tracking-wide uppercase">Product Leader · AI Builder</p>
    <h1 class="text-5xl font-bold text-gray-900 leading-tight mb-8">
      Seven years building B2B products. Now proving how fast the right product leader can create value.
    </h1>
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <p class="text-xl text-gray-500 leading-relaxed mb-10">
          I led product at B2B marketplaces for seven years. My thesis: the time and resources needed to go from idea to working product have collapsed. AI-fluent product leaders can validate and iterate in days what used to take teams months. I'm building real products to test that.
        </p>
        <div class="flex items-center gap-4">
          <a
            href="/work"
            class="bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-700 transition-colors"
          >
            See what I'm building →
          </a>
          <a
            href="https://www.linkedin.com/in/kyle--mcleod/"
            target="_blank"
            rel="noopener"
            class="text-gray-600 font-medium hover:text-gray-900 transition-colors flex items-center gap-1"
          >
            Connect on LinkedIn →
          </a>
        </div>
      </div>
      <div class="hidden md:block">
        <HeroTerminal client:load />
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  {featuredWork.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 pb-24">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl font-bold text-gray-900">Selected work</h2>
        <a href="/work" class="text-sm font-medium text-accent-600 hover:text-accent-700 transition-colors">
          View all →
        </a>
      </div>
      <div class="flex flex-col gap-3">
        {featuredWork.map((entry) => {
          const toolList = entry.data.tools.length > 0 ? entry.data.tools : entry.data.primaryTools;
          return (
          <a
            href={`/work/${entry.slug}`}
            class="group flex flex-col gap-4 border border-gray-100 rounded-xl px-6 py-5 hover:border-gray-300 hover:bg-gray-50/60 transition-all duration-200"
          >
            <!-- Header: title + all tools (primary emphasized) + arrow -->
            <div class="flex items-center justify-between gap-4">
              <div class="flex items-center flex-wrap gap-2">
                <span class="text-sm font-semibold text-gray-400">{entry.data.title}</span>
                {toolList.map((tool: string) => {
                  const isPrimary = entry.data.primaryTools.includes(tool);
                  return (
                    <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${isPrimary ? "bg-sky-50 text-sky-600 border-sky-100" : "bg-gray-50 text-gray-400 border-gray-200"}`}>
                      {tool}
                    </span>
                  );
                })}
              </div>
              <span class="text-gray-300 group-hover:text-gray-600 transition-colors shrink-0">→</span>
            </div>

            <!-- Exploring -->
            <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">Exploring</span>
              </div>
              <p class="text-sm font-medium text-gray-900 leading-snug">
                {entry.data.learningQuestion ?? entry.data.description}
              </p>
            </div>

            <!-- Feature chips -->
            {entry.data.features.length > 0 && (
              <div class="flex flex-col gap-1.5">
              <div class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-xs font-medium text-gray-400 uppercase tracking-wide">Results</span>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                {entry.data.features.map((feature: { label: string; status: "done" | "active" | "planned" }) => (
                  <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border ${
                    feature.status === "done" ? "bg-gray-50 text-gray-500 border-gray-200" :
                    feature.status === "active" ? "bg-sky-50 text-sky-600 border-sky-100" :
                    "bg-white text-gray-300 border-gray-100"
                  }`}>
                    {feature.status === "done" && (
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                    )}
                    {feature.status === "active" && (
                      <span class="relative flex w-2 h-2 shrink-0">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sky-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full w-2 h-2 bg-sky-500"></span>
                      </span>
                    )}
                    {feature.status === "planned" && (
                      <svg width="8" height="8" viewBox="0 0 8 8" class="shrink-0 text-gray-300"><circle cx="4" cy="4" r="3.5" fill="none" stroke="currentColor" stroke-width="1"/></svg>
                    )}
                    {feature.label}
                  </span>
                ))}
              </div>
              </div>
            )}
          </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- About strip -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <div>
        <h2 class="text-3xl font-bold text-gray-900 mb-4">About me</h2>
        <div class="max-w-3xl">
          <p class="text-gray-500 leading-relaxed mb-4">
            Most recently, I was Director of Product at MacroFab, a ~$50M ARR electronics manufacturing marketplace. I owned pricing, quoting, and operational decisioning. Deployed an ML-driven pricing engine that automated 98% of transactions, improved panel margins from 25% to 41%, and drove a 114% increase in conversion. I also led productization of an agentic AI workflow for interpreting customer manufacturing documents, defining the human-in-the-loop review process and accuracy guardrails for production deployment.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            Before that, I owned acquisition and call-center platforms at AWL, a ~$200M ARR insurance marketplace. Ran platform-wide A/B testing programs that generated $12M in annual profit lift and used marketplace data to shift investment toward call-based conversion, driving a 30% revenue increase in Health and Medicare.
          </p>
          <p class="text-gray-500 leading-relaxed mb-4">
            I started as a mechanical engineer at Schlumberger. Seven years designing and delivering offshore drilling equipment through regulated, multimillion-dollar programs. That's where I learned systems thinking, constraints, and what it takes to ship something real.
          </p>
          <p class="text-gray-500 leading-relaxed">
            When I'm not building, I'm probably fly fishing.
          </p>
        </div>
        <div class="mt-10 pt-8 border-t border-gray-200">
          <CompanyLogos client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PortfolioGrid from '../../components/PortfolioGrid';
import { getCollection } from 'astro:content';

const entries = await getCollection('work');
const works = entries
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((e) => ({
    slug: e.slug,
    title: e.data.title,
    description: e.data.description,
    tags: e.data.tags,
    cover: e.data.cover ?? null,
    outcome: e.data.outcome ?? null,
    role: e.data.role ?? null,
  }));

const allTags = ['All', ...Array.from(new Set(works.flatMap((w) => w.tags)))];
---

<BaseLayout title="Work — Your Name" description="Case studies and product work.">
  <section class="max-w-5xl mx-auto px-6 pt-16 pb-24">
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-3">Work</h1>
      <p class="text-lg text-gray-500 max-w-xl">
        A selection of product work across growth, infrastructure, and consumer experiences.
      </p>
    </div>

    <PortfolioGrid works={works} allTags={allTags} client:load />
  </section>
</BaseLayout>

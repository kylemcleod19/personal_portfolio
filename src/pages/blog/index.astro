---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Blog — Your Name" description="Thoughts on product management, leadership, and building software.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-3">Blog</h1>
      <p class="text-lg text-gray-500">Thoughts on product management, leadership, and building software.</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-400">No posts yet — check back soon.</p>
    ) : (
      <ul class="divide-y divide-gray-100">
        {posts.map((post) => (
          <li class="py-8">
            <a href={`/blog/${post.slug}`} class="group block">
              <div class="flex flex-wrap gap-2 mb-2">
                {post.data.tags.map((tag) => (
                  <span class="text-xs font-medium text-gray-400">{tag}</span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-accent-600 transition-colors">
                {post.data.title}
              </h2>
              <p class="text-gray-500 text-sm mb-3">{post.data.description}</p>
              <time class="text-xs text-gray-400">{fmt(post.data.pubDate)}</time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
